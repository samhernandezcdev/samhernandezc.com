---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  class?: string;
}

const {
  id,
  eyebrow,
  title,
  description,
  class: className = "",
} = Astro.props;
---

<section id={id} class:list={["scroll-mt-24 py-24 sm:py-32", className]}>
  <div class="mx-auto max-w-6xl px-6">
    {(eyebrow || title || description) && (
      <div class="mb-14 max-w-2xl">
        {eyebrow && (
          <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-muted-foreground">
            <span class="h-1.5 w-1.5 rounded-full bg-primary" />
            {eyebrow}
          </div>
        )}

        {title && (
          <h2 class="text-balance text-3xl font-semibold tracking-tight sm:text-4xl">
            {title}
          </h2>
        )}

        {description && (
          <p class="mt-4 text-balance text-base text-muted-foreground sm:text-lg">
            {description}
          </p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>