---
import { Image } from "astro:assets";
import Section from "@/components/layout/Section.astro";
import { projects } from "@/data/projects";
import { ArrowUpRight } from "lucide-astro";
---

<Section
  id="proyectos"
  eyebrow="Proyectos Destacados"
  title="Trabajos seleccionados"
  description="Algunos proyectos que ponen de manifiesto mi enfoque del diseño, la ingeniería y la ejecución."
>
  <div class="grid gap-6 md:grid-cols-2">
    {projects.map((p, i) => (
      <article
        class={`group surface-card overflow-hidden rounded-2xl transition-all hover:border-brand/50 ${
          i === 0 ? "md:col-span-2" : ""
        }`}
      >
        <div class="relative aspect-video overflow-hidden border-b border-border bg-surface-2">
          <Image
            src={p.image}
            alt={p.title}
            loading="lazy"
            width={1200}
            height={800}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          />
          <div class="absolute inset-0 bg-linear-to-t from-background/60 to-transparent" />
        </div>
        <div class="p-6 sm:p-8">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-lg font-semibold tracking-tight sm:text-xl">
              {p.title}
            </h3>
            <div>
              <a
                href={p.live}
                aria-label="Live site"
                class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-surface hover:text-foreground"
              >
                <ArrowUpRight class="h-4 w-4" />
              </a>
            </div>
          </div>
          <p class="mt-2 text-sm text-muted-foreground">{p.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {p.tech.map((t) => (
              <span
                class="rounded-md border border-border bg-background/40 px-2 py-0.5 font-mono text-[11px] text-foreground/80"
              >
                {t}
              </span>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>
</Section>