---
import Section from "@/components/layout/Section.astro";
import { services } from "@/data/services";
---

<Section
  id="servicios"
  eyebrow="Servicios"
  title="¿Cómo puedo ayudarte?"
  description="Servicios enfocados en desarrollo de software, automatización e integración de sistemas."
>
  <div class="grid gap-px overflow-hidden rounded-2xl border border-border bg-border/60 sm:grid-cols-2 lg:grid-cols-3">
    {services.map((s) => (
      <div
        class="group relative bg-background p-6 transition-colors hover:bg-surface sm:p-8"
      >
        <div class="mb-5 inline-flex h-10 w-10 items-center justify-center rounded-lg border border-border bg-surface text-brand-glow transition-all group-hover:border-brand/60 group-hover:shadow-(--shadow-glow)">
          <s.icon class="h-5 w-5" />
        </div>
        <h3 class="text-base font-semibold tracking-tight">{s.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{s.description}</p>
      </div>
    ))}
  </div>
</Section>