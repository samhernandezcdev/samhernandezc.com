---
import Section from "@/components/layout/Section.astro";
import { skills } from "@/data/skills";
---

<Section
  id="skills"
  eyebrow="Skills"
  title="Conjunto de herramientas modernas"
  description="El conjunto de tecnologías que utilizo para desarrollar software sostenible de principio a fin."
>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {skills.map((s, idx) => (
      <div
        class="surface-card group rounded-2xl p-6 transition-all hover:border-brand/40"
      >
        <div class="mb-5 flex items-center justify-between">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">
            {s.title}
          </h3>
          <span class="font-mono text-xs text-muted-foreground/70">
            0{idx + 1}
          </span>
        </div>
        <div class="flex flex-wrap gap-2">
          {s.items.map((i) => (
            <span class="rounded-md border border-border bg-background/40 px-2.5 py-1 text-xs text-foreground/90 transition-colors group-hover:border-border">
              {i}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Section>