---
import Section from "@/components/layout/Section.astro";
import type { PageContent } from "@/i18n/pages";

interface Props {
  content: PageContent["skills"];
}

const { content } = Astro.props;
---

<Section
  id="skills"
  eyebrow={content.eyebrow}
  title={content.title}
  description={content.description}
>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {content.groups.map((s, idx) => (
      <div
        class:list={[
          "surface-card group rounded-2xl p-6 transition-all hover:border-brand/40",
          "reveal",
          idx === 1 && "reveal-delay-100",
          idx === 2 && "reveal-delay-200",
          idx === 3 && "reveal-delay-300",
          idx === 4 && "reveal-delay-400",
        ]}
        data-reveal
      >
        <div class="mb-5 flex items-center justify-between">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">
            {s.title}
          </h3>
          <span class="font-mono text-xs text-muted-foreground/70">
            0{idx + 1}
          </span>
        </div>
        <div class="flex flex-wrap gap-2">
          {s.items.map((i) => (
            <span class="rounded-md border border-border bg-background/40 px-2.5 py-1 text-xs text-foreground/90 transition-colors group-hover:border-border">
              {i}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Section>
