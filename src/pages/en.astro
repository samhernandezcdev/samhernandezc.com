---
import HomePage from "@/components/pages/HomePage.astro";
import { languages, pages } from "@/i18n/pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const language = "en";
const content = pages[language];
const settings = languages[language];
---

<BaseLayout
  title={content.meta.title}
  description={content.meta.description}
  lang={settings.htmlLang}
  ogLocale={settings.ogLocale}
  alternateLocales={[{ lang: languages.es.htmlLang, href: languages.es.path }]}
>
  <HomePage language={language} content={content} />
</BaseLayout>
